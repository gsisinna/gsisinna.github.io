---
import BaseLayout from "../layouts/BaseLayout.astro";

const siteUrl = Astro.site?.toString() ?? "https://gsisinna.github.io";
const searchUrl = new URL("/search/", siteUrl).toString();
const searchJsonLd = {
  "@context": "https://schema.org",
  "@type": "SearchResultsPage",
  name: "Search | gsisinna",
  url: searchUrl,
  description: "Search notes and articles on gsisinna.github.io.",
  inLanguage: "en"
};
---

<BaseLayout
  title="Search | gsisinna"
  description="Search notes, architecture write-ups, and project posts."
  jsonLd={searchJsonLd}
>
  <section class="panel panel-soft stagger" style="display:grid; gap:0.8rem; position:relative; overflow:hidden;">
    <div
      aria-hidden="true"
      style="position:absolute; inset:auto -26px -34px auto; width:150px; height:150px; border-radius:999px; background:radial-gradient(circle, rgba(115,217,255,0.14), rgba(115,217,255,0));"
    />
    <p class="term-label">search</p>
    <h1 class="term-headline" style="font-size:clamp(1.7rem,3.4vw,2.6rem); max-width:100%; text-wrap:pretty;">Find notes quickly</h1>
    <p class="muted" style="max-width:78ch;">
      Search titles, excerpts, and tags across the journal. Results update as you type.
    </p>
    <label class="search-box" for="site-search-input">
      <span class="search-icon" aria-hidden="true">/</span>
      <input
        id="site-search-input"
        type="search"
        name="q"
        placeholder="Search topics, tags, or terms..."
        autocomplete="off"
        spellcheck="false"
      />
    </label>
    <div class="meta-row" aria-live="polite">
      <span class="pill" id="search-status">Loading index...</span>
      <span class="pill" id="search-count">0 results</span>
      <span class="pill" id="search-range">Page 1</span>
    </div>
  </section>

  <section class="panel panel-elevated" style="display:grid; gap:0.8rem;">
    <div id="search-empty" class="terminal-card">
      <div class="bar">
        <span class="traffic" aria-hidden="true"><span></span><span></span><span></span></span>
        <span class="title">search.help</span>
      </div>
      <div class="body" style="display:grid; gap:0.55rem;">
        <p class="muted">Try searching for topics like:</p>
        <div class="meta-row">
          <button class="search-chip" type="button" data-query="astro">astro</button>
          <button class="search-chip" type="button" data-query="software architecture">software architecture</button>
          <button class="search-chip" type="button" data-query="robotics">robotics</button>
          <button class="search-chip" type="button" data-query="blog">blog</button>
        </div>
      </div>
    </div>

    <div id="search-results" class="search-results" aria-live="polite"></div>
    <div id="search-pagination" class="search-pagination" hidden>
      <button type="button" class="button button-secondary" id="search-prev">Previous</button>
      <span class="pill" id="search-page-label">Page 1 of 1</span>
      <button type="button" class="button button-secondary" id="search-next">Next</button>
    </div>
  </section>

  <script is:inline>
    (() => {
      const input = document.getElementById("site-search-input");
      const status = document.getElementById("search-status");
      const count = document.getElementById("search-count");
      const range = document.getElementById("search-range");
      const results = document.getElementById("search-results");
      const pagination = document.getElementById("search-pagination");
      const prevBtn = document.getElementById("search-prev");
      const nextBtn = document.getElementById("search-next");
      const pageLabel = document.getElementById("search-page-label");
      const empty = document.getElementById("search-empty");
      const chips = Array.from(document.querySelectorAll("[data-query]"));

      if (!(input instanceof HTMLInputElement) || !(results instanceof HTMLElement)) return;

      let index = [];
      let ready = false;
      let currentPage = 1;
      const pageSize = 8;
      let lastMatches = [];

      const formatDate = (iso) => {
        try {
          return new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", year: "numeric" }).format(new Date(iso));
        } catch {
          return iso;
        }
      };

      const escapeHtml = (value) =>
        value
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/\"/g, "&quot;")
          .replace(/'/g, "&#39;");

      const escapeRegex = (value) => value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");

      const highlightHtml = (value, query) => {
        const safe = escapeHtml(value);
        const terms = Array.from(new Set(query.toLowerCase().split(/\s+/).filter((t) => t.length >= 2)));
        if (terms.length === 0) return safe;
        const pattern = terms.map((t) => escapeRegex(t)).join("|");
        if (!pattern) return safe;
        const regex = new RegExp(`(${pattern})`, "ig");
        return safe.replace(regex, "<mark>$1</mark>");
      };

      const rank = (post, query) => {
        const q = query.toLowerCase().trim();
        if (!q) return 0;
        const title = post.title.toLowerCase();
        const excerpt = post.excerpt.toLowerCase();
        const tags = post.tags.join(" ").toLowerCase();
        let score = 0;
        if (title.includes(q)) score += 6;
        if (tags.includes(q)) score += 4;
        if (excerpt.includes(q)) score += 2;
        const words = q.split(/\s+/).filter(Boolean);
        for (const word of words) {
          if (title.includes(word)) score += 2;
          if (tags.includes(word)) score += 1;
          if (excerpt.includes(word)) score += 1;
        }
        return score;
      };

      const renderPage = () => {
        if (!(results instanceof HTMLElement)) return;
        const total = lastMatches.length;
        const totalPages = Math.max(1, Math.ceil(total / pageSize));
        currentPage = Math.min(Math.max(1, currentPage), totalPages);
        const start = (currentPage - 1) * pageSize;
        const end = Math.min(total, start + pageSize);
        const pageItems = lastMatches.slice(start, end);

        if (range) {
          range.textContent = total > 0 ? `${start + 1}-${end} shown` : "Page 1";
        }
        if (pageLabel) {
          pageLabel.textContent = `Page ${currentPage} of ${totalPages}`;
        }
        if (pagination instanceof HTMLElement) {
          pagination.hidden = total <= pageSize;
        }
        if (prevBtn instanceof HTMLButtonElement) {
          prevBtn.disabled = currentPage <= 1;
        }
        if (nextBtn instanceof HTMLButtonElement) {
          nextBtn.disabled = currentPage >= totalPages;
        }

        if (pageItems.length === 0) {
          results.innerHTML = `
            <div class="terminal-card">
              <div class="bar">
                <span class="traffic" aria-hidden="true"><span></span><span></span><span></span></span>
                <span class="title">search.log</span>
              </div>
              <div class="body">
                <p class="muted">No results yet. Try a broader keyword or a tag name.</p>
              </div>
            </div>
          `;
          return;
        }

        results.innerHTML = pageItems
          .map(({ post }) => `
            <article class="search-result-card">
              <a class="search-result-link compact" href="/journal/${encodeURIComponent(post.id)}/">
                <div class="search-result-body">
                  <div class="search-result-top">
                    <h2>${highlightHtml(post.title, input.value)}</h2>
                    <span class="pill">${escapeHtml(formatDate(post.date))}</span>
                  </div>
                  <p class="muted">${highlightHtml(post.excerpt, input.value)}</p>
                  <div class="search-result-meta-line">
                    ${post.readingTime ? `<span class="pill">${escapeHtml(post.readingTime)}</span>` : ""}
                    <div class="meta-row search-result-meta">
                      ${post.tags.slice(0, 3).map((tag) => `<span class="pill">#${highlightHtml(tag, input.value)}</span>`).join("")}
                    </div>
                  </div>
                </div>
              </a>
            </article>
          `)
          .join("");
      };

      const renderResults = (query) => {
        const q = query.trim();
        if (!ready) {
          if (status) status.textContent = "Loading index...";
          return;
        }

        if (!q) {
          results.innerHTML = "";
          if (status) status.textContent = "Type to search";
          if (count) count.textContent = "0 results";
          if (range) range.textContent = "Page 1";
          lastMatches = [];
          currentPage = 1;
          if (pagination instanceof HTMLElement) pagination.hidden = true;
          if (empty) empty.hidden = false;
          return;
        }

        const matches = index
          .map((post) => ({ post, score: rank(post, q) }))
          .filter((item) => item.score > 0)
          .sort((a, b) => {
            if (b.score !== a.score) return b.score - a.score;
            return new Date(b.post.date).getTime() - new Date(a.post.date).getTime();
          })
          .slice(0, 100);

        if (status) status.textContent = matches.length > 0 ? `Searching for: ${q}` : `No match for: ${q}`;
        if (count) count.textContent = `${matches.length} result${matches.length === 1 ? "" : "s"}`;
        if (empty) empty.hidden = matches.length > 0 || q.length > 0;
        lastMatches = matches;
        currentPage = 1;
        renderPage();
      };

      for (const chip of chips) {
        if (!(chip instanceof HTMLButtonElement)) continue;
        chip.addEventListener("click", () => {
          input.value = chip.dataset.query ?? "";
          renderResults(input.value);
          input.focus();
        });
      }

      input.addEventListener("input", () => renderResults(input.value));
      if (prevBtn instanceof HTMLButtonElement) {
        prevBtn.addEventListener("click", () => {
          currentPage -= 1;
          renderPage();
        });
      }
      if (nextBtn instanceof HTMLButtonElement) {
        nextBtn.addEventListener("click", () => {
          currentPage += 1;
          renderPage();
        });
      }

      const params = new URLSearchParams(window.location.search);
      const initialQ = params.get("q") ?? "";
      if (initialQ) input.value = initialQ;

      fetch("/search-index.json")
        .then((response) => response.json())
        .then((data) => {
          index = Array.isArray(data) ? data : [];
          ready = true;
          if (status) status.textContent = "Type to search";
          renderResults(input.value);
        })
        .catch(() => {
          ready = true;
          if (status) status.textContent = "Search index unavailable";
        });
    })();
  </script>

  <style>
    .search-box {
      display: grid;
      grid-template-columns: auto 1fr;
      align-items: center;
      gap: 0.55rem;
      border: 1px solid rgba(82,255,168,0.14);
      background: rgba(255,255,255,0.012);
      border-radius: 12px;
      padding: 0.65rem 0.75rem;
    }

    .search-icon {
      color: var(--accent);
      font-family: "JetBrains Mono", ui-monospace, monospace;
      font-size: 0.95rem;
      line-height: 1;
    }

    .search-box input {
      width: 100%;
      border: 0;
      outline: 0;
      background: transparent;
      color: var(--ink-strong);
      font: inherit;
      min-width: 0;
    }

    .search-box input::placeholder {
      color: var(--muted);
    }

    .search-chip {
      border: 1px solid rgba(82,255,168,0.1);
      background: rgba(255,255,255,0.012);
      color: var(--muted);
      border-radius: 999px;
      padding: 0.32rem 0.55rem;
      font: inherit;
      font-size: 0.74rem;
      cursor: pointer;
    }

    .search-chip:hover {
      color: var(--ink-strong);
      border-color: rgba(82,255,168,0.18);
      background: rgba(82,255,168,0.04);
    }

    .search-results {
      display: grid;
      gap: 0.75rem;
      min-width: 0;
    }

    .search-results > * {
      min-width: 0;
    }

    .search-result-card {
      border: 1px solid rgba(82,255,168,0.1);
      border-radius: 12px;
      overflow: hidden;
      background: linear-gradient(to bottom, rgba(255,255,255,0.018), rgba(255,255,255,0.006));
      min-width: 0;
    }

    .search-result-link {
      display: grid;
      grid-template-columns: minmax(0, 180px) minmax(0, 1fr);
      text-decoration: none;
      color: inherit;
      min-width: 0;
      align-items: start;
    }

    .search-result-link.no-image,
    .search-result-link.compact {
      grid-template-columns: 1fr;
    }

    .search-result-link > img {
      width: 100%;
      aspect-ratio: 16 / 10;
      height: auto;
      max-height: 140px;
      object-fit: cover;
      display: block;
      border-right: 1px solid rgba(82,255,168,0.08);
      background: rgba(255,255,255,0.01);
      align-self: start;
    }

    .search-result-link.compact > img {
      display: none;
    }

    .search-result-body {
      display: grid;
      gap: 0.55rem;
      padding: 0.75rem;
      min-width: 0;
      align-content: start;
    }

    .search-result-link.compact .search-result-body {
      gap: 0.45rem;
      padding: 0.7rem 0.8rem;
    }

    .search-result-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.75rem;
      flex-wrap: wrap;
      min-width: 0;
    }

    .search-result-top h2 {
      margin: 0;
      font-size: 1rem;
      line-height: 1.2;
      text-wrap: pretty;
      max-width: 42ch;
      min-width: 0;
      flex: 1 1 18rem;
      overflow-wrap: anywhere;
    }

    .search-result-top .pill {
      flex-shrink: 0;
    }

    .search-result-body :where(h2, p, .pill) mark {
      background: rgba(255, 209, 102, 0.16);
      color: var(--ink-strong);
      border-radius: 4px;
      padding: 0 0.18em;
      box-shadow: inset 0 0 0 1px rgba(255, 209, 102, 0.14);
    }

    .search-result-body p {
      margin: 0;
      font-size: 0.88rem;
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
      overflow-wrap: anywhere;
    }

    .search-result-meta {
      align-items: flex-start;
      min-width: 0;
    }

    .search-result-meta-line {
      display: flex;
      gap: 0.5rem;
      align-items: flex-start;
      flex-wrap: wrap;
      min-width: 0;
    }

    .search-result-meta-line > .pill {
      flex-shrink: 0;
    }

    .search-result-meta .pill {
      max-width: 100%;
      white-space: normal;
      overflow-wrap: anywhere;
      line-height: 1.2;
    }

    @media (max-width: 760px) {
      .search-result-link {
        grid-template-columns: 1fr;
      }

      .search-result-link > img {
        border-right: 0;
        border-bottom: 1px solid rgba(82,255,168,0.08);
        max-height: 170px;
        width: 100%;
      }

      .search-result-top {
        gap: 0.45rem;
      }

      .search-result-top h2 {
        max-width: 100%;
        font-size: 0.96rem;
      }

      .search-result-body {
        padding: 0.65rem;
      }

      .search-result-meta {
        gap: 0.35rem;
      }
    }

    .search-pagination {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.6rem;
      flex-wrap: wrap;
    }

    .search-pagination .button {
      padding: 0.5rem 0.75rem;
    }

    .search-pagination .button:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    @media (max-width: 520px) {
      .search-pagination {
        display: grid;
        grid-template-columns: 1fr;
      }

      .search-pagination .button {
        width: 100%;
      }
    }
  </style>
</BaseLayout>
