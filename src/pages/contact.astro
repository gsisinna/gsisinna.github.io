---
import BaseLayout from "../layouts/BaseLayout.astro";

const siteUrl = Astro.site?.toString() ?? "https://gsisinna.github.io";
const contactUrl = new URL("/contact/", siteUrl).toString();
const contactJsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Contact | Gabriele Sisinna",
  url: contactUrl,
  description: "Contact page for project inquiries, collaborations, and robotics/software architecture work.",
  inLanguage: "en"
};
---

<BaseLayout
  title="Contact | Gabriele Sisinna"
  description="Get in touch about robotics software, architecture support, prototyping, or collaboration."
  jsonLd={contactJsonLd}
>
  <section class="panel panel-soft stagger" style="display:grid; gap:0.8rem;">
    <p class="term-label">contact</p>
    <h1 class="term-headline" style="font-size:clamp(1.8rem,4vw,3rem);">Let&apos;s talk</h1>
    <p class="muted" style="max-width:62ch;">
      If you are working on a robotics, automation, or software architecture project, send a short message.
      I am open to collaborations, technical discussions, and hands-on implementation work.
    </p>
    <div class="command command-typing" style="--type-ch:32; --type-delay:260ms; --type-duration:1.35s;">
      <span class="prompt">gsisinna@blog:~/contact$</span>
      <code>submit message --subject "hello"</code>
    </div>
  </section>

  <section class="panel panel-elevated tilt-card" style="display:grid; gap:0.9rem;">
    <div class="terminal-card">
      <div class="bar">
        <span class="traffic" aria-hidden="true"><span></span><span></span><span></span></span>
        <span class="title">compose_message.form</span>
      </div>
      <div class="body">
        <form
          method="POST"
          action="https://formspree.io/f/xzdakabw"
          accept-charset="UTF-8"
          referrerpolicy="no-referrer"
          autocomplete="on"
          style="display:grid; gap:0.75rem;"
        >
          <input type="hidden" name="_subject" value="New message from gsisinna.github.io" />
          <input type="hidden" name="_next" value="https://gsisinna.github.io/contact/" />
          <label aria-hidden="true" style="position:absolute; left:-10000px; width:1px; height:1px; overflow:hidden;">
            Do not fill this out
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
          </label>

          <label style="display:grid; gap:0.35rem;">
            <span class="eyebrow">Name</span>
            <input
              type="text"
              name="name"
              required
              minlength="2"
              maxlength="100"
              autocomplete="name"
              placeholder="Your name"
              style="width:100%; background:rgba(255,255,255,0.015); color:var(--ink-strong); border:1px solid var(--line); border-radius:9px; padding:0.75rem; font:inherit;"
            />
          </label>

          <label style="display:grid; gap:0.35rem;">
            <span class="eyebrow">Email</span>
            <input
              type="email"
              name="email"
              required
              maxlength="254"
              autocomplete="email"
              autocapitalize="off"
              spellcheck="false"
              inputmode="email"
              placeholder="you@example.com"
              style="width:100%; background:rgba(255,255,255,0.015); color:var(--ink-strong); border:1px solid var(--line); border-radius:9px; padding:0.75rem; font:inherit;"
            />
          </label>

          <label style="display:grid; gap:0.35rem;">
            <span class="eyebrow">Subject</span>
            <input
              type="text"
              name="subject"
              required
              minlength="3"
              maxlength="150"
              autocomplete="off"
              placeholder="Project, collaboration, question..."
              style="width:100%; background:rgba(255,255,255,0.015); color:var(--ink-strong); border:1px solid var(--line); border-radius:9px; padding:0.75rem; font:inherit;"
            />
          </label>

          <label style="display:grid; gap:0.35rem;">
            <span class="eyebrow">Message</span>
            <textarea
              name="message"
              required
              minlength="10"
              maxlength="5000"
              rows="7"
              placeholder="Write your message..."
              style="width:100%; resize:vertical; min-height:10rem; background:rgba(255,255,255,0.015); color:var(--ink-strong); border:1px solid var(--line); border-radius:9px; padding:0.75rem; font:inherit;"
            ></textarea>
          </label>

          <div style="display:flex; gap:0.6rem; flex-wrap:wrap; align-items:center;">
            <button type="submit" class="button button-primary" style="cursor:pointer;">
              Send message
            </button>
            <span class="muted" style="font-size:0.78rem;">
              Messages are submitted through Formspree (third-party processor). Please avoid passwords, credentials, or sensitive data.
            </span>
          </div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
