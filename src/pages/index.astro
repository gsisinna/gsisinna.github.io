    .recent-card {
      isolation: isolate;
    }

    .recent-card::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at var(--mx, 50%) var(--my, 50%), rgba(82,255,168,0.07), transparent 46%);
