    .jumpbar {
      position: sticky;
      top: 0.7rem;
      z-index: 12;
      display: flex;
      align-items: center;
      gap: 0.45rem;
      flex-wrap: wrap;
      padding: 0.55rem;
      background:
        linear-gradient(to right, rgba(12,15,19,0.94), rgba(12,15,19,0.78));
      box-shadow: 0 14px 30px rgba(0,0,0,0.2);
