---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublishedJournalEntries, formatDate } from "../lib/content";

const entries = await getPublishedJournalEntries();
const latest = entries.slice(0, 3);
---

<BaseLayout
  title="gsisinna | Personal Blog"
  description="A minimal personal blog for notes, projects, ideas, and progress."
>
  <section class="panel panel-soft stagger hero-grid tilt-card">
    <div style="display:grid; gap:0.9rem; align-content:start; min-width:0;">
      <p class="term-label">init personal-space</p>
      <h1 class="term-headline">Notes, projects, ideas, and the work behind them.</h1>
      <p class="muted" style="font-size:1.02rem; max-width:46ch;">
        A clean, minimal space to document what I am building, learning, noticing, and
        thinking about. Part journal, part lab notes, part personal archive.
      </p>
      <div class="command">
        <span class="prompt">gsisinna@blog:~$</span>
        <code>ls ./notes --latest 3</code>
      </div>
      <div style="display:flex; gap:0.6rem; flex-wrap:wrap;">
        <a href="/journal/" class="button button-primary">Read notes</a>
        <a href="#recent" class="button button-secondary">Latest posts</a>
      </div>
      <div class="meta-row">
        <span class="pill">Writing</span>
        <span class="pill">Projects</span>
        <span class="pill">Learning</span>
        <span class="pill">Ideas</span>
      </div>
      <div class="divider" />
      <div class="mini-stat-grid">
        <div class="mini-tile">
          <p class="eyebrow">Focus</p>
          <p style="margin-top:0.2rem;">Notes + snapshots</p>
        </div>
        <div class="mini-tile">
          <p class="eyebrow">Style</p>
          <p style="margin-top:0.2rem;">Minimal + polished</p>
        </div>
        <div class="mini-tile">
          <p class="eyebrow">Goal</p>
          <p style="margin-top:0.2rem;">Create + reflect</p>
        </div>
      </div>
    </div>

    <aside class="panel panel-elevated tilt-card" style="display:grid; gap:0.8rem; align-content:start; position:relative; overflow:hidden;">
      <div aria-hidden="true" class="orb-3d" style="inset:auto -22px -18px auto;" />
      <p class="term-label">why this exists</p>
      <h2 style="font-size:1.25rem;" class="term-headline">A small terminal for memory and work</h2>
      <div class="terminal-card">
        <div class="bar">
          <span class="traffic" aria-hidden="true"><span></span><span></span><span></span></span>
          <span class="title">journal.log</span>
        </div>
        <div class="body" style="display:grid; gap:0.55rem;">
          <div class="command"><span class="prompt">[01]</span><code>capture moments + progress</code></div>
          <div class="command"><span class="prompt">[02]</span><code>keep context around decisions</code></div>
          <div class="command"><span class="prompt">[03]</span><code>build a useful personal archive</code></div>
        </div>
      </div>
    </aside>
  </section>

  <section id="recent" style="display:grid; gap:0.9rem;">
    <div class="panel panel-soft section-head">
      <div>
        <p class="term-label">recent output</p>
        <h2 class="term-headline">Latest notes</h2>
      </div>
      <a href="/journal/" class="button button-secondary" style="padding:0.55rem 0.8rem;">See all</a>
    </div>

    <div class="stagger" style="display:grid; gap:0.75rem;">
      {latest.map((entry, index) => (
        <a
          href={`/journal/${entry.slug}/`}
          class="panel panel-elevated card-link tilt-card"
          style="position:relative; overflow:hidden;"
        >
          <div
            aria-hidden="true"
            style={`position:absolute; inset:0 auto 0 0; width:4px; opacity:0.65; background:${
              index % 3 === 0 ? "var(--accent)" : index % 3 === 1 ? "var(--accent-warm)" : "#495ed1"
            };`}
          />
          <div style="display:flex; justify-content:space-between; gap:1rem; align-items:center; flex-wrap:wrap; padding-left:0.35rem;">
            <h3 style="font-size:1rem;" class="term-headline">{entry.data.title}</h3>
            <span class="pill">{formatDate(entry.data.date)}</span>
          </div>
          <p class="muted" style="padding-left:0.35rem;">{entry.data.excerpt}</p>
          <div class="meta-row" style="padding-left:0.35rem;">
            {entry.data.tags.map((tag) => <span class="pill">#{tag}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>

  <style>
    @media (max-width: 900px) {
      section:first-child .panel:first-child {
        grid-template-columns: 1fr;
      }

      section:first-child [class~="mini-stat-grid"] {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
