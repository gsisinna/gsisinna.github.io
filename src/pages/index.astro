---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimelineIcon from "../components/TimelineIcon.astro";
import { getPublishedJournalEntries, formatDate } from "../lib/content";

const entries = await getPublishedJournalEntries();
const latest = entries.slice(0, 3);
const featured = latest[0];
const totalPosts = entries.length;
const siteUrl = Astro.site?.toString() ?? "https://gsisinna.github.io";
const homeUrl = new URL("/", siteUrl).toString();
const notesUrl = new URL("/journal/", siteUrl).toString();
const contactUrl = new URL("/contact/", siteUrl).toString();
const searchUrl = new URL("/search/", siteUrl).toString();
const githubUrl = "https://github.com/gsisinna";
const linkedInUrl = "https://www.linkedin.com/in/gabriele-sisinna-4a6081109/";
const homeJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "gsisinna",
    url: homeUrl,
    description:
      "Personal blog of Gabriele Sisinna about robotics software, projects, and notes.",
    inLanguage: "en",
    potentialAction: {
      "@type": "SearchAction",
      target: `${searchUrl}?q={search_term_string}`,
      "query-input": "required name=search_term_string"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Gabriele Sisinna",
    url: homeUrl,
    jobTitle: "Senior Robotics Software Engineer",
    address: {
      "@type": "PostalAddress",
      addressLocality: "Bologna",
      addressCountry: "IT"
    },
    knowsAbout: [
      "Robotics",
      "C++",
      "Python",
      "Linux",
      "Arduino",
      "Electronics",
      "3D Printing",
      "Rapid Prototyping",
      "ROS",
      "Robotics Simulation",
      "Control Systems",
      "Software Architecture"
    ],
    sameAs: [githubUrl, contactUrl, linkedInUrl].filter(Boolean),
    mainEntityOfPage: homeUrl
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "Main site sections",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", url: homeUrl },
      { "@type": "ListItem", position: 2, name: "Notes", url: notesUrl },
      { "@type": "ListItem", position: 3, name: "Contact", url: contactUrl }
    ]
  }
];

const storyline = [
  {
    period: "2024 -> now",
    place: "FlexLink · Bologna",
    role: "Robotics Software Engineer",
    icon: "factory",
    current: true,
    note:
      "I work on modular C++/Python software for autonomous and collaborative robotics, with a strong focus on reusable components, CI/CD, and system integration."
  },
  {
    period: "2022 -> 2023",
    place: "Lab0 · Genova",
    role: "Robotics Engineer",
    icon: "cube",
    current: false,
    note:
      "This was a hands-on role across simulation, middleware, C++/Python development, Docker/Git workflows, hardware integration, and prototyping."
  },
  {
    period: "2021 -> 2022",
    place: "Istituto Italiano di Tecnologia · Genova",
    role: "Robotics Technician / Robotics Software Engineer",
    icon: "robot",
    current: false,
    note:
      "I worked on iCub assembly, testing, diagnostics, YARP-based test activities, Docker deployments, and technical support for demos and public events."
  },
  {
    period: "2021",
    place: "Università di Pisa",
    role: "Master Thesis",
    icon: "thesis",
    current: false,
    note:
      "My master thesis focused on a bio-inspired control system for the humanoid robot Abel, with a ROS-based architecture written in Python."
  },
  {
    period: "2020 -> 2021",
    place: "Scuola Superiore Sant'Anna · Pisa",
    role: "Lab Training - Robotics",
    icon: "academy",
    current: false,
    note:
      "Training work on a 7DOF KUKA simulation using ROS/MoveIt/Gazebo, CLIK, PID control, trajectory planning, and Linux-based robotics workflows."
  }
];

const certifications = [
  {
    title: "Software Architecture Foundations",
    issuer: "LinkedIn Learning",
    issued: "2024",
    focus: "Software Architecture"
  },
  {
    title: "Learning C++",
    issuer: "LinkedIn Learning",
    issued: "2023",
    focus: "C++"
  },
  {
    title: "Learning Python",
    issuer: "LinkedIn Learning",
    issued: "2020",
    focus: "Python"
  },
  {
    title: "Programming Foundations: Object-Oriented Design",
    issuer: "LinkedIn Learning",
    issued: "2020",
    focus: "OOP / Design"
  },
  {
    title: "Programming Foundations: Algorithms",
    issuer: "LinkedIn Learning",
    issued: "2020",
    focus: "Algorithms"
  }
];

const skillGroups = [
  {
    title: "Software",
    items: ["C++", "Python", "CMake", "Software Architecture", "Unit Testing", "CI/CD"]
  },
  {
    title: "Robotics",
    items: ["ROS", "Simulation", "Control Systems", "Industrial Manipulators", "Middleware", "System Integration"]
  },
  {
    title: "Systems & Tools",
    items: ["Linux", "Docker", "Git / GitLab", "DevOps", "Arduino", "Embedded Prototyping"]
  },
  {
    title: "Hardware & Prototyping",
    items: ["Electronics", "3D Printing", "CAD", "Onshape", "Rapid Prototyping", "Hardware Integration"]
  }
];

const education = [
  {
    title: "MSc in Bionics Engineering (Biorobotics)",
    school: "Scuola Superiore Sant'Anna",
    period: "2018-2021"
  },
  {
    title: "BSc in Biomedical Engineering",
    school: "Università di Pisa",
    period: "2014-2018"
  }
];

const hobbies = [
  {
    label: "Guitar",
    value: "Playing guitar is one of the ways I slow down. It keeps me patient and grounded, and it reminds me that good things are built one repeat at a time."
  },
  {
    label: "Motorcycle",
    value: "Riding gives me freedom and focus at the same time. It clears my head, sharpens attention, and gives me the same sense of flow I look for when building software."
  },
  {
    label: "Trekking",
    value: "Trekking is how I reset. Nature gives me space and perspective, and I feel a strong connection to mountain landscapes because of my roots near Mount Etna in Sicily."
  }
];
---

<BaseLayout
  title="Gabriele Sisinna | Personal Blog"
  description="Robotics software engineer in Bologna sharing projects, notes, prototyping work, and software architecture thinking for robotics and automation."
  jsonLd={homeJsonLd}
>
  <div class="home-page">
  <div class="home-progress" aria-hidden="true"><span id="home-progress-bar"></span></div>

  <section id="top" class="panel panel-soft stagger hero-grid tilt-card home-hero home-section">
    <div style="display:grid; gap:0.9rem; align-content:start; min-width:0;">
      <p class="term-label">whoami</p>
      <h1 class="term-headline" style="max-width:100%; text-wrap:pretty;">Gabriele Sisinna</h1>
      <p style="color:var(--ink-strong); font-size:0.95rem; max-width:100%; text-wrap:pretty;">
        Robotics Software · C++ · Python · Software Architecture
      </p>
      <p class="muted" style="font-size:1.02rem; max-width:62ch;">
        Based in Bologna, I build robotics software for simulation, control, and integration, with a strong focus
        on software architecture. I also work hands-on with Linux systems, Arduino, electronics, 3D printing,
        and rapid prototyping when projects need real hardware and fast iteration.
      </p>
      <div class="social-links" aria-label="Social links">
        <a class="social-link" href={githubUrl} target="_blank" rel="noreferrer noopener" aria-label="GitHub profile">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M12 2C6.48 2 2 6.58 2 12.23c0 4.52 2.87 8.36 6.84 9.71.5.1.68-.22.68-.5 0-.24-.01-1.03-.01-1.87-2.78.62-3.37-1.21-3.37-1.21-.46-1.2-1.11-1.52-1.11-1.52-.91-.64.07-.63.07-.63 1 .08 1.53 1.06 1.53 1.06.9 1.57 2.35 1.12 2.92.86.09-.67.35-1.12.64-1.38-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.04 1.03-2.76-.1-.26-.45-1.31.1-2.74 0 0 .84-.28 2.75 1.05A9.3 9.3 0 0 1 12 6.84c.85 0 1.71.12 2.52.37 1.91-1.33 2.75-1.05 2.75-1.05.55 1.43.2 2.48.1 2.74.64.72 1.03 1.64 1.03 2.76 0 3.94-2.34 4.8-4.57 5.06.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.81 0 .28.18.61.69.5A10.26 10.26 0 0 0 22 12.23C22 6.58 17.52 2 12 2Z"
            />
          </svg>
          <span>GitHub</span>
        </a>
        <a class="social-link" href={linkedInUrl} target="_blank" rel="noreferrer noopener" aria-label="LinkedIn profile">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M6.94 8.5A1.56 1.56 0 1 0 6.9 5.38a1.56 1.56 0 0 0 .04 3.12ZM5.6 9.67h2.62V18H5.6V9.67Zm4.27 0h2.51v1.14h.03c.35-.66 1.2-1.35 2.47-1.35 2.64 0 3.12 1.78 3.12 4.1V18h-2.61v-3.91c0-.93-.02-2.13-1.27-2.13-1.28 0-1.48 1.03-1.48 2.06V18H9.87V9.67Z"
            />
          </svg>
          <span>LinkedIn</span>
        </a>
        <a class="social-link" href={contactUrl} aria-label="Contact page">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M3 6.75A2.75 2.75 0 0 1 5.75 4h12.5A2.75 2.75 0 0 1 21 6.75v10.5A2.75 2.75 0 0 1 18.25 20H5.75A2.75 2.75 0 0 1 3 17.25V6.75Zm2 .17v.16l7 4.88 7-4.88v-.16a.75.75 0 0 0-.75-.75H5.75a.75.75 0 0 0-.75.75Zm14 2.59-6.43 4.48a1 1 0 0 1-1.14 0L5 9.51v7.74c0 .41.34.75.75.75h12.5c.41 0 .75-.34.75-.75V9.51Z"
            />
          </svg>
          <span>Contact</span>
        </a>
      </div>
      <div class="command command-typing" style="--type-ch:14; --type-delay:220ms; --type-duration:1s;">
        <span class="prompt">gabriele@gsisinna:~$</span>
        <code>cat profile.md</code>
      </div>
      <div style="display:flex; gap:0.6rem; flex-wrap:wrap;">
        {featured ? (
          <a href={`/journal/${featured.id}/`} class="button button-primary">Read latest note</a>
        ) : (
          <a href="/journal/" class="button button-primary">Browse notes</a>
        )}
        <a href="/journal/" class="button button-secondary">View archive</a>
        <a href="/contact/" class="button button-secondary">Work together</a>
      </div>
      <div class="divider" />
      <div class="mini-stat-grid">
        <div class="mini-tile">
          <p class="eyebrow">Base</p>
          <p style="margin-top:0.2rem;">Bologna, IT</p>
        </div>
        <div class="mini-tile">
          <p class="eyebrow">Languages</p>
          <p style="margin-top:0.2rem;">IT · EN</p>
        </div>
        <div class="mini-tile">
          <p class="eyebrow">Posts</p>
          <p style="margin-top:0.2rem;">{totalPosts}</p>
        </div>
      </div>
    </div>

    <aside class="panel panel-elevated tilt-card" style="display:grid; gap:0.8rem; align-content:start; position:relative; overflow:hidden;">
      <div aria-hidden="true" class="orb-3d" style="inset:auto -22px -18px auto;" />
      <div class="availability-strip availability-strip-plain" aria-label="Availability">
        <span class="availability-badge"><span class="dot"></span>Online</span>
      </div>
      <figure class="hero-avatar">
        <img
          src="/avatar-profile.jpg"
          alt="Gabriele Sisinna working on a humanoid robot"
          loading="eager"
          decoding="async"
          width="220"
          height="220"
        />
      </figure>
      <p class="term-label">how to reach me</p>
      <h2 style="font-size:1.12rem;" class="term-headline">Let&apos;s Talk</h2>
      <div class="terminal-card">
        <div class="bar">
          <span class="traffic" aria-hidden="true"><span></span><span></span><span></span></span>
          <span class="title">contact.sh</span>
        </div>
        <div class="body" style="display:grid; gap:0.55rem;">
          <div class="command command-typing" style="--type-ch:13; --type-delay:520ms; --type-duration:0.9s;"><span class="prompt">$</span><code>open /contact</code></div>
          <div class="command command-typing" style="--type-ch:21; --type-delay:980ms; --type-duration:1.2s;"><span class="prompt">$</span><code>write a short message</code></div>
          <div class="command command-typing" style="--type-ch:4; --type-delay:1540ms; --type-duration:0.5s;"><span class="prompt">$</span><code>send</code></div>
        </div>
      </div>
    </aside>
  </section>

  <nav class="panel panel-soft jumpbar stagger" aria-label="Homepage sections">
    <a href="#timeline" data-jump>timeline</a>
    <a href="#toolbox" data-jump>skills</a>
    <a href="#about" data-jump>about</a>
    <a href="#recent" data-jump>notes</a>
    <a href="/contact/" class="jumpbar-cta">contact</a>
  </nav>

  <section id="timeline" class="panel panel-elevated stagger tilt-card home-section home-section-accent" style="display:grid; gap:0.85rem;">
    <div class="section-head">
      <div>
        <p class="term-label">career timeline</p>
        <h2 class="term-headline" style="max-width:100%; text-wrap:pretty;">Path so far</h2>
      </div>
      <span class="pill">Bologna / Genova / Pisa</span>
    </div>

    <div class="terminal-card">
      <div class="bar">
        <span class="traffic" aria-hidden="true"><span></span><span></span><span></span></span>
        <span class="title">timeline.log</span>
      </div>
      <div class="body">
        <div class="timeline">
        {storyline.map((step, index) => (
          <div class="timeline-item">
            <div class="timeline-marker" aria-hidden="true">
              <span class:list={["timeline-dot", step.current && "current"]}></span>
            </div>
            <div class:list={["timeline-card", step.current && "current"]}>
              <div class="timeline-top">
                <span class="pill">
                  #{String(index + 1).padStart(2, "0")} · {step.period}
                  {step.current ? " · current" : ""}
                </span>
                <span class="timeline-place">{step.place}</span>
              </div>
              <div class="timeline-role-row">
                <span class="timeline-icon" aria-hidden="true"><TimelineIcon kind={step.icon} /></span>
                <p class="timeline-role">{step.role}</p>
              </div>
              <p class="muted" style="font-size:0.84rem;">{step.note}</p>
            </div>
          </div>
        ))}
        </div>
      </div>
    </div>
  </section>

  <section id="toolbox" class="panel panel-soft stagger home-section home-section-accent" style="display:grid; gap:0.85rem;">
    <div class="section-head">
      <div>
        <p class="term-label">toolbox</p>
        <h2 class="term-headline" style="max-width:100%; text-wrap:pretty;">Skills, tools, and prototyping work</h2>
      </div>
      <span class="pill">software + hardware workflow</span>
    </div>

    <div class="grid-2">
      <div class="terminal-card">
        <div class="bar">
          <span class="traffic" aria-hidden="true"><span></span><span></span><span></span></span>
          <span class="title">skills.txt</span>
        </div>
        <div class="body" style="display:grid; gap:0.7rem;">
          {skillGroups.map((group) => (
            <div class="panel" style="padding:0.7rem; border-radius:10px; display:grid; gap:0.45rem;">
              <div style="display:flex; justify-content:space-between; gap:0.5rem; align-items:center; flex-wrap:wrap;">
                <p style="color:var(--ink-strong); font-size:0.82rem;">{group.title}</p>
                <span class="pill">{group.items.length} items</span>
              </div>
              <div class="meta-row">
                {group.items.map((item) => <span class="pill">{item}</span>)}
              </div>
            </div>
          ))}

          <div class="panel" style="padding:0.7rem; border-radius:10px; display:grid; gap:0.35rem;">
            <p style="color:var(--ink-strong); font-size:0.82rem;">Languages</p>
            <p class="muted" style="font-size:0.82rem;">
              Italiano (native/bilingual) · English (professional working)
            </p>
          </div>
        </div>
      </div>

      <div class="terminal-card">
        <div class="bar">
          <span class="traffic" aria-hidden="true"><span></span><span></span><span></span></span>
          <span class="title">education_and_certs.md</span>
        </div>
        <div class="body" style="display:grid; gap:0.7rem;">
          <div class="panel" style="padding:0.7rem; border-radius:10px; display:grid; gap:0.5rem;">
            <div style="display:flex; justify-content:space-between; gap:0.5rem; align-items:center; flex-wrap:wrap;">
              <p style="color:var(--ink-strong); font-size:0.82rem;">Education</p>
              <span class="pill">{education.length} entries</span>
            </div>
            <div style="display:grid; gap:0.45rem;">
              {education.map((item) => (
                <div class="panel" style="padding:0.65rem; border-radius:9px; display:grid; gap:0.2rem;">
                  <div style="display:flex; justify-content:space-between; gap:0.5rem; align-items:center; flex-wrap:wrap;">
                    <p style="color:var(--ink-strong); font-size:0.82rem;">{item.title}</p>
                    <span class="pill">{item.period}</span>
                  </div>
                  <p class="muted" style="font-size:0.78rem;">{item.school}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="panel" style="padding:0.7rem; border-radius:10px; display:grid; gap:0.5rem;">
            <div style="display:flex; justify-content:space-between; gap:0.5rem; align-items:center; flex-wrap:wrap;">
              <p style="color:var(--ink-strong); font-size:0.82rem;">Selected certifications</p>
              <span class="pill">{certifications.length}</span>
            </div>
            <div style="display:grid; gap:0.4rem;">
              {certifications.map((cert, idx) => (
                <div class="command" style="padding:0.45rem 0.6rem;">
                  <span class="prompt">[{String(idx + 1).padStart(2, "0")}]</span>
                  <div style="display:grid; gap:0.12rem; min-width:0;">
                    <code>{cert.title}</code>
                    <span class="muted" style="font-size:0.72rem;">
                      {cert.issuer} · {cert.issued} · {cert.focus}
                    </span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="about" class="panel panel-elevated stagger tilt-card home-section home-section-accent" style="display:grid; gap:0.85rem;">
    <div class="section-head">
      <div>
        <p class="term-label">about me</p>
        <h2 class="term-headline" style="max-width:100%; text-wrap:pretty;">Outside work</h2>
      </div>
      <span class="pill">Life</span>
    </div>

    <div class="grid-2">
      <div class="terminal-card">
        <div class="bar">
          <span class="traffic" aria-hidden="true"><span></span><span></span><span></span></span>
          <span class="title">about_me.md</span>
        </div>
        <div class="body" style="display:grid; gap:0.65rem;">
          <p class="muted" style="font-size:0.84rem;">
            Outside robotics and software, I try to stay close to things that keep me grounded:
            music, riding, photography, and time in nature. I come from Sicily, near Mount Etna, and
            I have always felt a strong connection to both mountains and the sea.
          </p>
          <div class="divider" />
          <div style="display:grid; gap:0.45rem;">
            <div class="command"><span class="prompt">$</span><code>play guitar</code></div>
            <div class="command"><span class="prompt">$</span><code>ride motorcycle</code></div>
            <div class="command"><span class="prompt">$</span><code>shoot photos</code></div>
            <div class="command"><span class="prompt">$</span><code>go trekking</code></div>
            <div class="command"><span class="prompt">$</span><code>read books</code></div>
            <div class="command"><span class="prompt">$</span><code>go running</code></div>
            <div class="command"><span class="prompt">$</span><code>meet friends</code></div>
          </div>
        </div>
      </div>

      <div class="terminal-card">
        <div class="bar">
          <span class="traffic" aria-hidden="true"><span></span><span></span><span></span></span>
          <span class="title">hobbies.log</span>
        </div>
        <div class="body" style="display:grid; gap:0.55rem;">
          {hobbies.map((item, index) => (
            <div class="panel" style="padding:0.7rem; border-radius:10px; display:grid; gap:0.25rem;">
              <div style="display:flex; justify-content:space-between; gap:0.5rem; flex-wrap:wrap; align-items:center;">
                <p style="color:var(--ink-strong); font-size:0.82rem;">{item.label}</p>
                <span class="pill">#{String(index + 1).padStart(2, "0")}</span>
              </div>
              <p class="muted" style="font-size:0.82rem;">{item.value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="recent" class="home-section" style="display:grid; gap:0.9rem;">
    <div class="panel panel-soft section-head home-section-accent">
      <div>
        <p class="term-label">blog notes</p>
        <h2 class="term-headline" style="max-width:100%; text-wrap:pretty;">Projects and notes</h2>
      </div>
      <a href="/journal/" class="button button-secondary" style="padding:0.55rem 0.8rem;">See all notes</a>
    </div>

    <div class="stagger" style="display:grid; gap:0.75rem;">
      {latest.map((entry, index) => (
        <a
          href={`/journal/${entry.id}/`}
          class="panel panel-elevated card-link tilt-card recent-card"
          style="position:relative; overflow:hidden;"
        >
          <div
            aria-hidden="true"
            style={`position:absolute; inset:0 auto 0 0; width:4px; opacity:0.65; background:${
              index % 3 === 0 ? "var(--accent)" : index % 3 === 1 ? "var(--accent-warm)" : "#495ed1"
            };`}
          />
          <div style="display:flex; justify-content:space-between; gap:1rem; align-items:center; flex-wrap:wrap; padding-left:0.35rem;">
            <h3 style="font-size:1rem;" class="term-headline">{entry.data.title}</h3>
            <span class="pill">{formatDate(entry.data.date)}</span>
          </div>
          <p class="muted" style="padding-left:0.35rem;">{entry.data.excerpt}</p>
          <div class="meta-row" style="padding-left:0.35rem;">
            {entry.data.tags.map((tag) => <span class="pill">#{tag}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>
  </div>

  <style>
    .home-page {
      display: grid;
      gap: 0.95rem;
      position: relative;
    }

    .home-page::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 12% 18%, rgba(82,255,168,0.045), transparent 32%),
        radial-gradient(circle at 84% 12%, rgba(115,217,255,0.04), transparent 34%);
      z-index: 0;
    }

    .home-progress {
      position: sticky;
      top: 0;
      z-index: 15;
      height: 3px;
      border-radius: 999px;
      overflow: hidden;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(82,255,168,0.06);
