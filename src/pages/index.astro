      border: 1px solid rgba(82,255,168,0.08);
      border-radius: 8px;
      padding: 0.42rem 0.7rem;
      font-size: 0.78rem;
      line-height: 1;
      background: rgba(255,255,255,0.012);
      transition: 160ms ease;
      white-space: nowrap;
    }

    .jumpbar a:hover,
    .jumpbar a.is-active {
