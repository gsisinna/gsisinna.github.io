      z-index: 1;
    }

    .section-head .term-headline {
      position: relative;
      display: inline-block;
      padding-bottom: 0.15rem;
    }

    .section-head .term-headline::after {
      content: "";
      position: absolute;
      left: 0;
      right: auto;
      bottom: -0.2rem;
