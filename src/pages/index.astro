    .home-section-accent {
      overflow: hidden;
      position: relative;
    }

    .home-section-accent::after {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        linear-gradient(130deg, rgba(255,255,255,0.02), transparent 24%),
