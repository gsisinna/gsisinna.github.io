---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublishedJournalEntries, formatDate } from "../lib/content";

const entries = await getPublishedJournalEntries();
const latest = entries.slice(0, 3);
const featured = latest[0];
const totalPosts = entries.length;

const storyline = [
  {
    period: "2024 -> now",
    place: "FlexLink · Bologna",
    role: "Robotics Software Engineer",
    note:
      "Designing modular C++/Python software for autonomous and collaborative robotics, with reusable components, CI/CD, and industrial system integration."
  },
  {
    period: "2022 -> 2023",
    place: "Lab0 · Genova",
    role: "Robotics Engineer",
    note:
      "Robotics simulation, middleware, C++/Python development, Docker/Git workflows, hardware integration, and prototyping."
  },
  {
    period: "2021 -> 2022",
    place: "Istituto Italiano di Tecnologia · Genova",
    role: "Robotics Technician / Robotics Software Engineer",
    note:
      "iCub assembly, testing, diagnostics, YARP-based test work, Docker deployments, and technical support for public demos and events."
  },
  {
    period: "2021",
    place: "Università di Pisa",
    role: "Master Thesis",
    note:
      "Master thesis on a bio-inspired control system for social humanoid robots (Abel), with a ROS-based architecture in Python."
  },
  {
    period: "2020 -> 2021",
    place: "Scuola Superiore Sant'Anna · Pisa",
    role: "Lab Training - Robotics",
    note:
      "7DOF KUKA simulation with ROS/MoveIt/Gazebo, CLIK, PID control, trajectory planning, and Linux robotics workflows."
  }
];

const certifications = [
  "Simscape Onramp",
  "Control Design Onramp with Simulink",
  "Linear Algebra with Matlab",
  "Onshape Introduction to Part Design",
  "Became a good Matlab programmer in 30 days"
];
---

<BaseLayout
  title="Gabriele Sisinna | Personal Blog"
  description="Senior Robotics Software Engineer (C++/Python) sharing notes, projects, and process in a terminal-style personal blog."
>
  <section class="panel panel-soft stagger hero-grid tilt-card">
    <div style="display:grid; gap:0.9rem; align-content:start; min-width:0;">
      <p class="term-label">whoami</p>
      <h1 class="term-headline">Gabriele Sisinna</h1>
      <p style="color:var(--ink-strong); font-size:0.95rem;">
        Senior Robotics Software Engineer | C++ · Python · Software Architecture
      </p>
      <p class="muted" style="font-size:1.02rem; max-width:46ch;">
        Based in Bologna. I build robotics software focused on simulation, control
        systems, integration, and maintainable architectures that can move from research to production.
      </p>
      <div class="command">
        <span class="prompt">gabriele@gsisinna:~$</span>
        <code>cat profile.md</code>
      </div>
      <div style="display:flex; gap:0.6rem; flex-wrap:wrap;">
        {featured ? (
          <a href={`/journal/${featured.slug}/`} class="button button-primary">Start here</a>
        ) : (
          <a href="/journal/" class="button button-primary">Open notes</a>
        )}
        <a href="/journal/" class="button button-secondary">Open archive</a>
        <a href="/contact/" class="button button-secondary">Contact</a>
      </div>
      <div class="meta-row">
        <span class="pill">Robotica</span>
        <span class="pill">C++</span>
        <span class="pill">Python</span>
        <span class="pill">ROS</span>
        <span class="pill">Simulation</span>
      </div>
      <div class="divider" />
      <div class="mini-stat-grid">
        <div class="mini-tile">
          <p class="eyebrow">Base</p>
          <p style="margin-top:0.2rem;">Bologna, IT</p>
        </div>
        <div class="mini-tile">
          <p class="eyebrow">Languages</p>
          <p style="margin-top:0.2rem;">IT · EN</p>
        </div>
        <div class="mini-tile">
          <p class="eyebrow">Posts</p>
          <p style="margin-top:0.2rem;">{totalPosts}</p>
        </div>
      </div>
    </div>

    <aside class="panel panel-elevated tilt-card" style="display:grid; gap:0.8rem; align-content:start; position:relative; overflow:hidden;">
      <div aria-hidden="true" class="orb-3d" style="inset:auto -22px -18px auto;" />
      <p class="term-label">how to reach me</p>
      <h2 style="font-size:1.12rem;" class="term-headline">Use the contact form</h2>
      <div class="terminal-card">
        <div class="bar">
          <span class="traffic" aria-hidden="true"><span></span><span></span><span></span></span>
          <span class="title">contact.sh</span>
        </div>
        <div class="body" style="display:grid; gap:0.55rem;">
          <div class="command"><span class="prompt">$</span><code>open /contact</code></div>
          <div class="command"><span class="prompt">$</span><code>write a short message</code></div>
          <div class="command"><span class="prompt">$</span><code>send</code></div>
        </div>
      </div>
      <div class="terminal-card">
        <div class="bar">
          <span class="traffic" aria-hidden="true"><span></span><span></span><span></span></span>
          <span class="title">focus.cfg</span>
        </div>
        <div class="body" style="display:grid; gap:0.45rem;">
          <p class="muted">
            Industrial robotics software, simulation, control systems, and software architecture.
          </p>
        </div>
      </div>
    </aside>
  </section>

  <section class="panel panel-elevated stagger tilt-card" style="display:grid; gap:0.85rem;">
    <div class="section-head">
      <div>
        <p class="term-label">career timeline</p>
        <h2 class="term-headline">Path: robotics labs -> industrial software</h2>
      </div>
      <span class="pill">Bologna / Genova / Pisa</span>
    </div>

    <div class="terminal-card">
      <div class="bar">
        <span class="traffic" aria-hidden="true"><span></span><span></span><span></span></span>
        <span class="title">timeline.log</span>
      </div>
      <div class="body" style="display:grid; gap:0.6rem;">
        {storyline.map((step, index) => (
          <div class="panel" style="padding:0.75rem; border-radius:10px; display:grid; gap:0.35rem;">
            <div style="display:flex; justify-content:space-between; gap:0.8rem; flex-wrap:wrap; align-items:center;">
              <span class="pill">#{String(index + 1).padStart(2, "0")} · {step.period}</span>
              <span class="muted" style="font-size:0.78rem;">{step.place}</span>
            </div>
            <p style="color:var(--ink-strong); font-weight:600; font-size:0.9rem;">{step.role}</p>
            <p class="muted" style="font-size:0.84rem;">{step.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="panel panel-soft stagger" style="display:grid; gap:0.85rem;">
    <div class="section-head">
      <div>
        <p class="term-label">toolbox</p>
        <h2 class="term-headline">Core skills, education, and certifications</h2>
      </div>
      <span class="pill">robotics + software</span>
    </div>

    <div class="grid-2">
      <div class="terminal-card">
        <div class="bar">
          <span class="traffic" aria-hidden="true"><span></span><span></span><span></span></span>
          <span class="title">skills.txt</span>
        </div>
        <div class="body" style="display:grid; gap:0.55rem;">
          <div class="meta-row">
            <span class="pill">Robotica</span>
            <span class="pill">C++</span>
            <span class="pill">Python</span>
            <span class="pill">ROS</span>
            <span class="pill">CMake</span>
            <span class="pill">Docker</span>
            <span class="pill">Git / GitLab</span>
            <span class="pill">CI/CD</span>
            <span class="pill">Simulation</span>
            <span class="pill">Control Systems</span>
          </div>
          <div class="divider" />
          <p class="muted" style="font-size:0.84rem;">
            Languages: Italiano (native), Inglese (professional working).
          </p>
        </div>
      </div>

      <div class="terminal-card">
        <div class="bar">
          <span class="traffic" aria-hidden="true"><span></span><span></span><span></span></span>
          <span class="title">education_and_certs.md</span>
        </div>
        <div class="body" style="display:grid; gap:0.6rem;">
          <div class="panel" style="padding:0.7rem; border-radius:10px; display:grid; gap:0.25rem;">
            <p style="color:var(--ink-strong); font-size:0.86rem;">MSc in Bionics Engineering (Biorobotics)</p>
            <p class="muted" style="font-size:0.78rem;">Scuola Superiore Sant'Anna · 2018-2021</p>
          </div>
          <div class="panel" style="padding:0.7rem; border-radius:10px; display:grid; gap:0.25rem;">
            <p style="color:var(--ink-strong); font-size:0.86rem;">BSc in Biomedical Engineering</p>
            <p class="muted" style="font-size:0.78rem;">Università di Pisa · 2014-2018</p>
          </div>
          <div class="panel" style="padding:0.7rem; border-radius:10px; display:grid; gap:0.35rem;">
            <p style="color:var(--ink-strong); font-size:0.82rem;">Selected certifications</p>
            <div class="meta-row">
              {certifications.map((cert) => <span class="pill">{cert}</span>)}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="recent" style="display:grid; gap:0.9rem;">
    <div class="panel panel-soft section-head">
      <div>
        <p class="term-label">blog notes</p>
        <h2 class="term-headline">Start here</h2>
      </div>
      <a href="/journal/" class="button button-secondary" style="padding:0.55rem 0.8rem;">Open notes</a>
    </div>

    <div class="stagger" style="display:grid; gap:0.75rem;">
      {latest.map((entry, index) => (
        <a
          href={`/journal/${entry.slug}/`}
          class="panel panel-elevated card-link tilt-card"
          style="position:relative; overflow:hidden;"
        >
          <div
            aria-hidden="true"
            style={`position:absolute; inset:0 auto 0 0; width:4px; opacity:0.65; background:${
              index % 3 === 0 ? "var(--accent)" : index % 3 === 1 ? "var(--accent-warm)" : "#495ed1"
            };`}
          />
          <div style="display:flex; justify-content:space-between; gap:1rem; align-items:center; flex-wrap:wrap; padding-left:0.35rem;">
            <h3 style="font-size:1rem;" class="term-headline">{entry.data.title}</h3>
            <span class="pill">{formatDate(entry.data.date)}</span>
          </div>
          <p class="muted" style="padding-left:0.35rem;">{entry.data.excerpt}</p>
          <div class="meta-row" style="padding-left:0.35rem;">
            {entry.data.tags.map((tag) => <span class="pill">#{tag}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>

  <style>
    @media (max-width: 900px) {
      section:first-child .panel:first-child {
        grid-template-columns: 1fr;
      }

      section:first-child [class~="mini-stat-grid"] {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
