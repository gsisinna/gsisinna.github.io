---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, getEntry, render } from "astro:content";
import { formatDate, slugifyTag } from "../../lib/content";

export async function getStaticPaths() {
  const entries = await getCollection("journal", ({ data }) => !data.draft);
  return entries.map((entry) => ({ params: { slug: entry.id } }));
}

const { slug } = Astro.params;

if (!slug) {
  throw new Error("Missing slug param");
}

const entry = await getEntry("journal", slug);

if (!entry || entry.data.draft) {
  return Astro.redirect("/journal/");
}

const { Content, headings } = await render(entry);
const siteUrl = Astro.site?.toString() ?? "https://gsisinna.github.io";
const postUrl = new URL(`/journal/${entry.id}/`, siteUrl).toString();
const homeUrl = new URL("/", siteUrl).toString();
const contactUrl = new URL("/contact/", siteUrl).toString();
const rssUrl = new URL("/rss.xml", siteUrl).toString();
const githubUrl = "https://github.com/gsisinna";
const linkedInUrl = "https://www.linkedin.com/in/gabriele-sisinna-4a6081109/";
const publishedIso = entry.data.date.toISOString();
const postImage = entry.data.image ?? "/og-article-default.svg";
const postImageUrl = new URL(postImage, siteUrl).toString();
const allPosts = await getCollection("journal", ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter((post) => post.id !== entry.id)
  .map((post) => {
    const sharedTags = post.data.tags.filter((tag) => entry.data.tags.includes(tag));
    return { post, sharedTags, score: sharedTags.length };
  })
  .filter((item) => item.score > 0)
  .sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score;
    return b.post.data.date.getTime() - a.post.data.date.getTime();
  })
  .slice(0, 3);
const tocHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const postJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: entry.data.title,
  description: entry.data.excerpt,
  datePublished: publishedIso,
  dateModified: publishedIso,
  url: postUrl,
  mainEntityOfPage: postUrl,
  inLanguage: "en",
  keywords: entry.data.tags.join(", "),
  image: postImageUrl,
  author: {
    "@type": "Person",
    name: "Gabriele Sisinna"
  },
  publisher: {
    "@type": "Person",
    name: "Gabriele Sisinna"
  }
};
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: homeUrl },
    { "@type": "ListItem", position: 2, name: "Notes", item: new URL("/journal/", siteUrl).toString() },
    { "@type": "ListItem", position: 3, name: entry.data.title, item: postUrl }
  ]
};
---

<BaseLayout
  title={`${entry.data.title} | gsisinna`}
  description={entry.data.excerpt}
  image={postImage}
  type="article"
  publishedTime={publishedIso}
  modifiedTime={publishedIso}
  tags={entry.data.tags}
  jsonLd={[postJsonLd, breadcrumbJsonLd]}
>
  <article class="panel panel-elevated tilt-card post-article" style="display:grid; gap:1rem; position:relative; overflow:hidden;">
    <div
      aria-hidden="true"
      class="orb-3d"
      style="width:180px; height:180px; inset:-30px -36px auto auto;"
    />
    <header class="stagger post-header" style="display:grid; gap:0.8rem; position:relative;">
      <a href="/journal/" class="button button-secondary" style="width:fit-content; padding:0.45rem 0.7rem;">← Back to notes</a>
      <p class="term-label">post view</p>
      <h1 class="term-headline post-title" style="font-size:clamp(1.6rem,3.1vw,2.45rem);">{entry.data.title}</h1>
      <div class="post-meta-stack" aria-label="Article metadata">
        <div class="meta-row">
          <span class="pill">{formatDate(entry.data.date)}</span>
          {entry.data.readingTime && <span class="pill">{entry.data.readingTime}</span>}
        </div>
        {entry.data.tags.length > 0 && (
          <div class="post-tag-row" aria-label="Article tags">
            <span class="post-tag-label">tags</span>
            <div class="meta-row">
              {entry.data.tags.map((tag) => (
                <a class="pill" href={`/tags/${slugifyTag(tag)}/`}>#{tag}</a>
              ))}
            </div>
          </div>
        )}
      </div>
      <p class="muted post-subtitle">{entry.data.excerpt}</p>
      {entry.data.image && (
        <figure class="post-cover">
          <img
            src={entry.data.image}
            alt={`${entry.data.title} featured image`}
            loading="eager"
            decoding="async"
            referrerpolicy="no-referrer"
          />
        </figure>
      )}
      <div class="command">
        <span class="prompt">less</span>
        <code>{entry.id}.md</code>
      </div>
    </header>

    <div class="divider" />

    {tocHeadings.length > 0 && (
      <aside class="post-toc panel panel-soft" aria-labelledby="post-toc-title" style="padding:0.8rem;">
        <div class="post-toc-shell">
          <p id="post-toc-title" class="term-label">contents</p>
          <nav class="post-toc-nav" aria-label="Table of contents">
            <ul class="post-toc-list">
              {tocHeadings.map((heading) => (
                <li class:list={["depth-item", heading.depth === 3 && "depth-3"]}>
                  <a href={`#${heading.slug}`}>{heading.text}</a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      </aside>
    )}

    <div class="prose post-prose" style="position:relative;">
      <Content />
    </div>

    <div class="divider" />

    <section class="post-author panel panel-soft" aria-labelledby="author-block-title" style="padding:0.85rem;">
      <div class="author-grid">
        <img
          class="author-avatar"
          src="/avatar-profile.jpg"
          alt="Gabriele Sisinna"
          loading="lazy"
          decoding="async"
          width="88"
          height="88"
        />
        <div style="display:grid; gap:0.45rem; min-width:0;">
          <p id="author-block-title" class="term-label">author</p>
          <h2 class="author-name">Gabriele Sisinna</h2>
          <p class="muted author-copy">
            Robotics software engineer focused on C++, Python, simulation, control, and system integration.
            This blog is where I document projects, architecture decisions, and lessons learned from real work.
          </p>
          <div class="author-links">
            <a href={homeUrl}>Home</a>
            <a href={githubUrl} target="_blank" rel="noreferrer noopener">GitHub</a>
            <a href={linkedInUrl} target="_blank" rel="noreferrer noopener">LinkedIn</a>
            <a href={contactUrl}>Contact</a>
          </div>
        </div>
      </div>
    </section>

    <section class="post-cta panel panel-elevated" aria-labelledby="post-cta-title" style="padding:0.85rem;">
      <div class="cta-shell">
        <div style="display:grid; gap:0.45rem;">
          <p class="term-label">follow</p>
          <h2 id="post-cta-title" class="cta-title">Keep reading / follow updates</h2>
          <p class="muted cta-copy">
            If this was useful, the easiest way to keep up is the RSS feed. You can also follow me on LinkedIn,
            check code and experiments on GitHub, or send a message if you want to discuss robotics software work.
          </p>
        </div>
        <div class="cta-actions">
          <a class="button button-primary" href={rssUrl}>Follow via RSS</a>
          <a class="button button-secondary" href={linkedInUrl} target="_blank" rel="noreferrer noopener">LinkedIn</a>
          <a class="button button-secondary" href={githubUrl} target="_blank" rel="noreferrer noopener">GitHub</a>
          <a class="button button-secondary" href={contactUrl}>Contact</a>
        </div>
      </div>
    </section>

    {relatedPosts.length > 0 && (
      <>
        <div class="divider" />
        <section class="post-related" aria-labelledby="related-posts-title" style="display:grid; gap:0.75rem;">
          <div style="display:flex; justify-content:space-between; align-items:center; gap:0.75rem; flex-wrap:wrap;">
            <p id="related-posts-title" class="term-label">related posts</p>
            <a href="/journal/" class="button button-secondary" style="padding:0.45rem 0.7rem;">View all notes</a>
          </div>
          <div class="related-grid">
            {relatedPosts.map(({ post, sharedTags }) => (
              <article class="related-card">
                <a href={`/journal/${post.id}/`} class="related-link">
                  {post.data.image && (
                    <img
                      src={post.data.image}
                      alt={`${post.data.title} thumbnail`}
                      loading="lazy"
                      decoding="async"
                      referrerpolicy="no-referrer"
                    />
                  )}
                  <div class="related-body">
                    <h2>{post.data.title}</h2>
                    <p class="muted">{post.data.excerpt}</p>
                    <div class="meta-row">
                      <span class="pill">{formatDate(post.data.date)}</span>
                      {sharedTags.slice(0, 2).map((tag) => <span class="pill">#{tag}</span>)}
                    </div>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </section>
      </>
    )}
  </article>
</BaseLayout>

<style>
  .post-header {
    max-width: 100%;
  }

  .post-title {
    max-width: 100%;
    text-wrap: pretty;
  }

  .post-subtitle {
    max-width: 100%;
  }

  .post-meta-stack {
    display: grid;
    gap: 0.45rem;
  }

  .post-tag-row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.55rem;
    align-items: start;
    min-width: 0;
  }

  .post-tag-label {
    color: var(--muted);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding-top: 0.25rem;
    font-family: "JetBrains Mono", ui-monospace, monospace;
  }

  .post-tag-row .pill {
    text-decoration: none;
  }

  .post-cover {
    margin: 0;
    max-width: min(100%, 920px);
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(82,255,168,0.12);
    background: rgba(255,255,255,0.01);
  }

  .post-cover img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .post-toc {
    max-width: min(100%, 980px);
  }

  .post-toc-shell {
    display: grid;
    gap: 0.45rem;
    min-width: 0;
  }

  .post-toc-nav {
    min-width: 0;
  }

  .post-toc-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.25rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    align-items: start;
  }

  .post-toc-list li {
    color: var(--muted);
    min-width: 0;
  }

  .post-toc-list a {
    display: block;
    color: inherit;
    text-decoration: none;
    border-left: 2px solid transparent;
    padding: 0.34rem 0.55rem;
    border-radius: 8px;
    line-height: 1.22;
    overflow-wrap: anywhere;
    text-wrap: pretty;
  }

  .post-toc-list a:hover {
    color: var(--ink-strong);
    border-left-color: rgba(82,255,168,0.28);
    background: rgba(82,255,168,0.04);
  }

  .post-toc-list .depth-3 {
    padding-left: 0.55rem;
    font-size: 0.94em;
    opacity: 0.95;
  }

  .post-toc-list .depth-3 a {
    border-left-color: rgba(255,255,255,0.06);
  }

  .post-prose {
    max-width: none;
  }

  /* Keep long-form text readable while allowing richer blocks to use more width */
  .post-prose > :where(p, ul, ol, h2, h3, blockquote) {
    max-width: 74ch;
  }

  .post-prose > :where(pre, figure, table) {
    max-width: 100%;
  }

  .post-prose :where(img) {
    max-width: 100%;
    height: auto;
  }

  .post-prose > figure {
    margin-left: 0;
    margin-right: 0;
  }

  .post-related {
    max-width: 100%;
  }

  .post-author,
  .post-cta {
    max-width: 100%;
  }

  .author-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.8rem;
    align-items: start;
  }

  .author-avatar {
    width: 88px;
    height: 88px;
    border-radius: 14px;
    object-fit: cover;
    display: block;
    border: 1px solid rgba(82,255,168,0.14);
    background: rgba(255,255,255,0.02);
  }

  .author-name {
    margin: 0;
    font-size: 1rem;
    line-height: 1.15;
  }

  .author-copy {
    margin: 0;
    max-width: 84ch;
    font-size: 0.9rem;
  }

  .author-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .author-links a {
    text-decoration: none;
    color: var(--muted);
    border: 1px solid rgba(82,255,168,0.1);
    background: rgba(255,255,255,0.012);
    border-radius: 8px;
    padding: 0.35rem 0.55rem;
    font-size: 0.76rem;
    line-height: 1;
  }

  .author-links a:hover {
    color: var(--ink-strong);
    border-color: rgba(82,255,168,0.2);
    background: rgba(82,255,168,0.04);
  }

  .cta-shell {
    display: grid;
    gap: 0.8rem;
  }

  .cta-title {
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.15;
    text-wrap: pretty;
  }

  .cta-copy {
    margin: 0;
    max-width: 84ch;
    font-size: 0.9rem;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .related-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .related-card {
    border: 1px solid rgba(82,255,168,0.1);
    border-radius: 12px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.018), rgba(255,255,255,0.006));
    overflow: hidden;
  }

  .related-link {
    display: grid;
    gap: 0;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .related-link > img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    border-bottom: 1px solid rgba(82,255,168,0.08);
  }

  .related-body {
    display: grid;
    gap: 0.55rem;
    padding: 0.7rem;
  }

  .related-body h2 {
    font-size: 0.95rem;
    margin: 0;
    line-height: 1.2;
    text-wrap: pretty;
  }

  .related-body p {
    font-size: 0.84rem;
    margin: 0;
  }

  @media (min-width: 980px) {
    .post-article {
      padding: 1.1rem 1.15rem;
    }

    .post-title {
      max-width: 42ch;
    }

    .post-subtitle {
      max-width: 88ch;
    }

    .post-prose > :where(p, ul, ol, h2, h3, blockquote) {
      max-width: 78ch;
    }
  }

  @media (max-width: 720px) {
    .post-toc {
      padding: 0.7rem;
    }

    .post-toc-list {
      grid-template-columns: 1fr;
      gap: 0.2rem;
    }

    .post-tag-row {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }

    .post-tag-label {
      padding-top: 0;
    }

    .author-grid {
      grid-template-columns: 1fr;
    }

    .author-avatar {
      width: 76px;
      height: 76px;
    }

    .cta-actions .button {
      width: 100%;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
