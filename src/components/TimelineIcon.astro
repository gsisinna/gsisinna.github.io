---
interface Props {
  kind: string;
}

const { kind } = Astro.props;
---

<svg
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  {kind === "factory" && (
    <>
      <path d="M3 21V9l7-3v4l7-3v14" />
      <path d="M3 21h18" />
      <path d="M7 21v-3" />
      <path d="M12 21v-3" />
      <path d="M17 21v-3" />
    </>
  )}
  {kind === "cube" && (
    <>
      <path d="m12 3 8 4.5-8 4.5-8-4.5Z" />
      <path d="M4 7.5V16.5L12 21l8-4.5V7.5" />
      <path d="M12 12v9" />
    </>
  )}
  {kind === "robot" && (
    <>
      <rect x="6" y="7" width="12" height="10" rx="2" />
      <path d="M12 4v3" />
      <path d="M9 11h.01" />
      <path d="M15 11h.01" />
      <path d="M9 17v2" />
      <path d="M15 17v2" />
    </>
  )}
  {kind === "thesis" && (
    <>
      <path d="M6 3h9l3 3v15H6z" />
      <path d="M15 3v4h4" />
      <path d="M9 12h6" />
      <path d="M9 16h6" />
    </>
  )}
  {kind === "academy" && (
    <>
      <path d="m3 10 9-5 9 5-9 5-9-5Z" />
      <path d="M7 12.5v3.5c0 .9 2.2 2 5 2s5-1.1 5-2v-3.5" />
      <path d="M21 10v6" />
    </>
  )}
  {!["factory", "cube", "robot", "thesis", "academy"].includes(kind) && <circle cx="12" cy="12" r="7" />}
</svg>
