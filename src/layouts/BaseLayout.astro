---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "Personal Notes",
  description = "A minimal personal blog for notes, projects, ideas, and the work behind them.",
  image = "/og-default.svg",
  noindex = false,
  type = "website",
  publishedTime,
  modifiedTime,
  tags = [],
  jsonLd = []
} = Astro.props;

const pathName = Astro.url.pathname;
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = new URL(pathName, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
const twitterCard = "summary_large_image";
const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
const currentYear = new Date().getFullYear();
const pageKeywords = [...new Set(["robotics software", "C++", "Python", "software architecture", ...tags])]
  .filter(Boolean)
  .join(", ");
const csp = [
  "default-src 'self'",
  "base-uri 'self'",
  "object-src 'none'",
  "form-action https://formspree.io",
  "img-src 'self' https: data:",
  "font-src 'self' https://fonts.gstatic.com data:",
  "style-src 'self' 'unsafe-inline' https://fonts.googleapis.com",
  "script-src 'self' 'unsafe-inline'",
  "connect-src 'self'",
  "upgrade-insecure-requests"
].join("; ");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={pageKeywords} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <meta name="googlebot" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"} />
    <meta name="author" content="Gabriele Sisinna" />
    <meta name="theme-color" content="#090b0e" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta http-equiv="Content-Security-Policy" content={csp} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:site_name" content="gsisinna" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content="gsisinna personal blog preview" />
    <meta property="og:locale" content="en_US" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {type === "article" && tags.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content="gsisinna personal blog preview" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    {jsonLdItems.filter(Boolean).map((item) => (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(item).replace(/</g, "\\u003c")}
      />
    ))}
    <!-- `frame-ancestors` is ignored in meta CSP. Enforce it via HTTP headers at the host/CDN. -->
    <script is:inline>
      if (window.top !== window.self) {
        document.documentElement.style.display = "none";
        try {
          window.top.location = window.self.location.href;
        } catch {}
      }
      document.documentElement.classList.add("js");
    </script>
    <style is:global>
      :root {
        --bg: #090b0e;
        --bg-2: #0d1014;
        --panel: rgba(13, 16, 20, 0.9);
        --panel-strong: rgba(17, 20, 26, 0.95);
        --ink: #d7ffe4;
        --ink-strong: #ecfff2;
        --muted: #8fb09d;
        --line: rgba(99, 255, 171, 0.12);
        --accent: #52ffa8;
        --accent-warm: #ffd166;
        --accent-cool: #73d9ff;
        --accent-soft: rgba(82, 255, 168, 0.1);
        --glow-1: rgba(82, 255, 168, 0.12);
        --glow-2: rgba(115, 217, 255, 0.1);
        --shadow: 0 28px 80px rgba(0, 0, 0, 0.5);
        --shadow-soft: 0 12px 24px rgba(0, 0, 0, 0.35);
        --radius: 14px;
        --radius-sm: 10px;
        --max: 1040px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        color-scheme: dark;
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--ink);
        background:
          radial-gradient(circle at 10% 8%, rgba(82, 255, 168, 0.08), transparent 35%),
          radial-gradient(circle at 88% 16%, rgba(115, 217, 255, 0.07), transparent 34%),
          linear-gradient(to bottom, rgba(255,255,255,0.01), rgba(255,255,255,0)),
          var(--bg);
        font-family: "IBM Plex Mono", "JetBrains Mono", ui-monospace, monospace;
        line-height: 1.55;
        min-height: 100vh;
        letter-spacing: -0.01em;
      }

      a {
        color: inherit;
      }

      a:focus-visible,
      button:focus-visible,
      input:focus-visible,
      textarea:focus-visible {
        outline: 2px solid rgba(82,255,168,0.65);
        outline-offset: 2px;
      }

      .skip-link {
        position: absolute;
        left: 0.75rem;
        top: -3rem;
        z-index: 1000;
        padding: 0.6rem 0.85rem;
        border-radius: 10px;
        border: 1px solid rgba(82,255,168,0.2);
        background: rgba(9,11,14,0.96);
        color: var(--ink-strong);
        text-decoration: none;
        box-shadow: 0 12px 24px rgba(0,0,0,0.25);
        transition: top 120ms ease;
      }

      .skip-link:focus {
        top: 0.7rem;
      }

      .shell {
        width: min(calc(100% - 2rem), var(--max));
        margin-inline: auto;
      }

      .frame {
        margin: 1rem auto 1.25rem;
        border: 1px solid var(--line);
        border-radius: 16px;
        background:
          linear-gradient(to bottom right, rgba(14, 17, 22, 0.98), rgba(9, 11, 15, 0.96)),
          radial-gradient(circle at 8% 0%, rgba(82,255,168,0.05), transparent 34%);
        backdrop-filter: blur(6px);
        box-shadow: var(--shadow);
        overflow: clip;
        position: relative;
        transform-style: preserve-3d;
      }

      .frame::before {
        content: "";
        position: absolute;
        inset: 0 0 auto 0;
        height: 1px;
        background: linear-gradient(
          to right,
          transparent,
          rgba(82,255,168,0.5),
          rgba(255,255,255,0.06),
          transparent
        );
        pointer-events: none;
      }

      .frame::after {
        content: "";
        position: absolute;
        inset: 0;
        background:
          repeating-linear-gradient(
            to bottom,
            rgba(255,255,255,0.02) 0,
            rgba(255,255,255,0.02) 1px,
            transparent 1px,
            transparent 3px
          );
        opacity: 0.08;
        pointer-events: none;
      }

      header.site {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.8rem 1rem;
        border-bottom: 1px solid var(--line);
        background:
          linear-gradient(to bottom, rgba(255,255,255,0.02), rgba(255,255,255,0));
        position: sticky;
        top: 0;
        z-index: 20;
        backdrop-filter: blur(10px);
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        text-decoration: none;
      }

      .traffic {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        margin-right: 0.25rem;
      }

      .traffic span {
        width: 0.55rem;
        height: 0.55rem;
        border-radius: 999px;
        display: inline-block;
        border: 1px solid rgba(255,255,255,0.08);
      }

      .traffic span:nth-child(1) { background: #ff5f56; }
      .traffic span:nth-child(2) { background: #ffbd2e; }
      .traffic span:nth-child(3) { background: #27c93f; }

      .brand-mark {
        width: 2.2rem;
        height: 1.4rem;
        border-radius: 7px;
        display: grid;
        place-items: center;
        background: rgba(82,255,168,0.08);
        border: 1px solid rgba(82,255,168,0.18);
        color: var(--accent);
        font-size: 0.8rem;
        font-family: "JetBrains Mono", ui-monospace, monospace;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
      }

      .brand-copy strong {
        display: block;
        font-size: 0.88rem;
        letter-spacing: 0;
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-weight: 600;
        color: var(--ink-strong);
      }

      .brand-copy span {
        display: block;
        color: var(--muted);
        font-size: 0.72rem;
      }

      nav {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        flex-wrap: wrap;
      }

      nav a {
        text-decoration: none;
        color: var(--muted);
        font-size: 0.82rem;
        padding: 0.4rem 0.65rem;
        border-radius: 8px;
        border: 1px solid var(--line);
        transition: 160ms ease;
        background: rgba(255,255,255,0.01);
      }

      nav a:hover,
      nav a[aria-current="page"] {
        color: var(--ink-strong);
        border-color: var(--line);
        background: rgba(82,255,168,0.05);
        box-shadow: inset 0 0 0 1px rgba(82,255,168,0.06);
      }

      main {
        padding: 1rem;
        display: grid;
        gap: 0.95rem;
      }

      .panel {
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background: var(--panel);
        padding: 1rem;
        box-shadow:
          inset 0 1px 0 rgba(255,255,255,0.03),
          inset 0 0 0 1px rgba(82,255,168,0.015);
        position: relative;
        transform-style: preserve-3d;
      }

      .panel-soft {
        background:
          linear-gradient(to bottom, rgba(16, 20, 25, 0.94), rgba(12, 15, 19, 0.9)),
          radial-gradient(circle at 90% 10%, rgba(115,217,255,0.05), transparent 44%);
      }

      .panel-elevated {
        background: var(--panel-strong);
        box-shadow: var(--shadow-soft);
      }

      .panel-elevated::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        background:
          linear-gradient(135deg, rgba(255,255,255,0.03), transparent 28%),
          radial-gradient(circle at 110% -5%, var(--glow-2), transparent 42%);
        pointer-events: none;
      }

      .eyebrow {
        color: var(--muted);
        font-size: 0.72rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      h1, h2, h3 {
        line-height: 1.1;
        margin: 0;
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-weight: 700;
      }

      h1 {
        font-size: clamp(1.8rem, 4.4vw, 3.2rem);
        letter-spacing: -0.02em;
        text-wrap: balance;
      }

      h2 {
        font-size: clamp(1.35rem, 3vw, 2rem);
        letter-spacing: -0.02em;
        text-wrap: balance;
      }

      p {
        margin: 0;
      }

      .muted {
        color: var(--muted);
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        border-radius: 7px;
        border: 1px solid rgba(82,255,168,0.12);
        background: rgba(82,255,168,0.03);
        padding: 0.3rem 0.55rem;
        font-size: 0.74rem;
        color: var(--muted);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
      }

      .button {
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.45rem;
        padding: 0.75rem 1rem;
        border-radius: 9px;
        border: 1px solid var(--line);
        transition: 160ms ease;
        transform-style: preserve-3d;
        font-size: 0.86rem;
        font-weight: 500;
      }

      .button:hover {
        transform: translateY(-1px) translateZ(0);
      }

      .button-primary {
        color: #fff;
        border-color: rgba(82,255,168,0.18);
        background: linear-gradient(135deg, #11161b, #111a1f 58%, #10342b);
        box-shadow: 0 10px 18px rgba(0, 0, 0, 0.24);
        position: relative;
        overflow: hidden;
      }

      .button-primary::after {
        content: "";
        position: absolute;
        inset: -100% auto auto -25%;
        width: 60%;
        height: 300%;
        background: linear-gradient(
          to right,
          transparent,
          rgba(255,255,255,0.18),
          transparent
        );
        transform: rotate(18deg);
        transition: transform 220ms ease;
        pointer-events: none;
      }

      .button-primary:hover::after {
        transform: translateX(26%) rotate(18deg);
      }

      .button-secondary {
        background: rgba(255,255,255,0.015);
      }

      .grid-2 {
        display: grid;
        gap: 0.95rem;
        grid-template-columns: 1.15fr 0.85fr;
        align-items: stretch;
      }

      .meta-row {
        display: flex;
        gap: 0.45rem;
        flex-wrap: wrap;
        align-items: center;
      }

      .section-head {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: end;
      }

      .card-link {
        text-decoration: none;
        display: grid;
        gap: 0.6rem;
        transition: 180ms ease;
        transform-style: preserve-3d;
      }

      .card-link:hover {
        transform: perspective(900px) translateY(-3px) rotateX(1.4deg);
        box-shadow: var(--shadow-soft);
      }

      .tilt-card {
        transform-style: preserve-3d;
      }

      .tilt-card > * {
        position: relative;
        z-index: 1;
      }

      .tilt-card::after {
        content: "";
        position: absolute;
        inset: auto 8% -20% 8%;
        height: 38%;
        background: radial-gradient(circle, rgba(0,0,0,0.34), transparent 70%);
        filter: blur(10px);
        pointer-events: none;
        z-index: 0;
      }

      .hero-grid {
        display: grid;
        gap: 0.95rem;
        grid-template-columns: 1.15fr 0.85fr;
        align-items: stretch;
      }

      .mini-stat-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.55rem;
      }

      .mini-tile {
        padding: 0.75rem;
        border-radius: 14px;
        border: 1px solid rgba(82,255,168,0.08);
        background:
          linear-gradient(to bottom, rgba(255,255,255,0.02), rgba(255,255,255,0.005));
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);
      }

      .orb-3d {
        position: absolute;
        width: 130px;
        height: 130px;
        border-radius: 999px;
        background:
          radial-gradient(circle at 30% 30%, rgba(255,255,255,0.08), transparent 38%),
          radial-gradient(circle at 60% 55%, rgba(82,255,168,0.22), rgba(82,255,168,0.03) 55%, transparent 72%),
          radial-gradient(circle at 60% 62%, rgba(115,217,255,0.12), transparent 70%);
        box-shadow:
          inset -12px -18px 28px rgba(0,0,0,0.22),
          inset 10px 10px 20px rgba(255,255,255,0.03),
          0 18px 26px rgba(0,0,0,0.18);
        filter: saturate(1.1);
        pointer-events: none;
      }

      .term-label {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--accent);
        font-size: 0.78rem;
        font-family: "JetBrains Mono", ui-monospace, monospace;
      }

      .term-label::before {
        content: "$";
        color: var(--accent-warm);
      }

      .term-headline::before {
        content: "> ";
        color: var(--accent);
      }

      .command {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        border: 1px solid rgba(82,255,168,0.12);
        background: rgba(82,255,168,0.025);
        border-radius: 9px;
        padding: 0.55rem 0.75rem;
        color: var(--ink-strong);
        font-size: 0.84rem;
      }

      .command .prompt {
        color: var(--accent);
      }

      .command code {
        background: transparent;
        border: 0;
        padding: 0;
        color: inherit;
        font-family: "JetBrains Mono", ui-monospace, monospace;
      }

      .command-typing {
        --type-ch: 12;
        --type-delay: 120ms;
        --type-duration: 1.1s;
      }

      .command-typing code {
        color: var(--accent);
        text-shadow: 0 0 14px rgba(82,255,168,0.12);
        position: relative;
      }

      .terminal-card {
        border-radius: 12px;
        border: 1px solid rgba(82,255,168,0.12);
        background:
          linear-gradient(to bottom, rgba(255,255,255,0.015), rgba(255,255,255,0.005));
        overflow: hidden;
      }

      .terminal-card .bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        padding: 0.45rem 0.6rem;
        border-bottom: 1px solid rgba(82,255,168,0.08);
        background: rgba(255,255,255,0.01);
      }

      .terminal-card .bar .title {
        color: var(--muted);
        font-size: 0.72rem;
      }

      .terminal-card .body {
        padding: 0.7rem;
      }

      .timeline {
        position: relative;
        display: grid;
        gap: 0.7rem;
      }

      .timeline::before {
        content: "";
        position: absolute;
        left: 0.9rem;
        top: 0.35rem;
        bottom: 0.35rem;
        width: 1px;
        background: linear-gradient(
          to bottom,
          rgba(82,255,168,0.35),
          rgba(82,255,168,0.16),
          rgba(115,217,255,0.2)
        );
      }

      .timeline-item {
        position: relative;
        display: grid;
        grid-template-columns: 1.9rem 1fr;
        gap: 0.7rem;
        align-items: start;
      }

      .timeline-marker {
        position: relative;
        width: 1.9rem;
        height: 100%;
        display: grid;
        place-items: start center;
        padding-top: 0.15rem;
      }

      .timeline-dot {
        width: 0.8rem;
        height: 0.8rem;
        border-radius: 999px;
        border: 1px solid rgba(82,255,168,0.34);
        background:
          radial-gradient(circle at 35% 35%, rgba(255,255,255,0.25), transparent 45%),
          radial-gradient(circle at 50% 50%, rgba(82,255,168,0.32), rgba(82,255,168,0.06) 72%, transparent 74%);
        box-shadow:
          0 0 0 4px rgba(82,255,168,0.035),
          0 0 16px rgba(82,255,168,0.12);
      }

      .timeline-dot.current {
        border-color: rgba(255,209,102,0.45);
        background:
          radial-gradient(circle at 35% 35%, rgba(255,255,255,0.28), transparent 42%),
          radial-gradient(circle at 50% 50%, rgba(255,209,102,0.35), rgba(255,209,102,0.06) 72%, transparent 74%);
        box-shadow:
          0 0 0 4px rgba(255,209,102,0.04),
          0 0 18px rgba(255,209,102,0.14);
      }

      .timeline-card {
        position: relative;
        border: 1px solid rgba(82,255,168,0.09);
        border-radius: 11px;
        background:
          linear-gradient(to bottom, rgba(255,255,255,0.018), rgba(255,255,255,0.006));
        padding: 0.75rem;
        display: grid;
        gap: 0.4rem;
      }

      .timeline-card.current {
        border-color: rgba(255,209,102,0.16);
        background:
          linear-gradient(to bottom, rgba(255,209,102,0.03), rgba(255,255,255,0.008));
      }

      .timeline-card::before {
        content: "";
        position: absolute;
        left: -7px;
        top: 0.75rem;
        width: 10px;
        height: 10px;
        transform: rotate(45deg);
        border-left: 1px solid rgba(82,255,168,0.09);
        border-bottom: 1px solid rgba(82,255,168,0.09);
        background: rgba(13,16,20,0.95);
      }

      .timeline-card.current::before {
        border-left-color: rgba(255,209,102,0.16);
        border-bottom-color: rgba(255,209,102,0.16);
      }

      .timeline-top {
        display: flex;
        justify-content: space-between;
        gap: 0.75rem;
        align-items: center;
        flex-wrap: wrap;
      }

      .timeline-role {
        color: var(--ink-strong);
        font-weight: 600;
        font-size: 0.9rem;
      }

      .timeline-place {
        color: var(--muted);
        font-size: 0.78rem;
      }

      .timeline-role-row {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        min-width: 0;
      }

      .timeline-icon {
        width: 1.7rem;
        height: 1.7rem;
        border-radius: 8px;
        display: inline-grid;
        place-items: center;
        border: 1px solid rgba(82,255,168,0.12);
        background:
          linear-gradient(to bottom, rgba(82,255,168,0.06), rgba(82,255,168,0.015));
        color: var(--accent);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
        flex-shrink: 0;
      }

      .timeline-card.current .timeline-icon {
        border-color: rgba(255,209,102,0.18);
        background:
          linear-gradient(to bottom, rgba(255,209,102,0.08), rgba(255,209,102,0.02));
        color: var(--accent-warm);
      }

      .timeline-icon svg {
        width: 0.95rem;
        height: 0.95rem;
        display: block;
      }

      .divider {
        height: 1px;
        background: linear-gradient(
          to right,
          rgba(22,21,19,0.04),
          rgba(237,241,245,0.12),
          rgba(22,21,19,0.04)
        );
      }

      footer.site {
        padding: 0.8rem 1.2rem 1.2rem;
        color: var(--muted);
        font-size: 0.8rem;
        border-top: 1px solid rgba(82,255,168,0.06);
        background: linear-gradient(to top, rgba(255,255,255,0.02), rgba(255,255,255,0));
      }

      .prose {
        max-width: 72ch;
        font-size: 0.96rem;
      }

      .prose p + p {
        margin-top: 1.05rem;
      }

      .prose :where(h2, h3) {
        margin-top: 1.6rem;
        margin-bottom: 0.75rem;
      }

      .prose ul,
      .prose ol {
        padding-left: 1.1rem;
        color: var(--ink);
      }

      .prose li + li {
        margin-top: 0.35rem;
      }

      .prose code {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.9em;
        background: rgba(82,255,168,0.04);
        border: 1px solid rgba(82,255,168,0.08);
        border-radius: 6px;
        padding: 0.08rem 0.35rem;
      }

      .prose pre {
        overflow-x: auto;
        border: 1px solid var(--line);
        border-radius: 14px;
        background: #090b0e;
        color: #d7ffe4;
        padding: 0.95rem;
        box-shadow:
          inset 0 1px 0 rgba(255,255,255,0.03),
          inset 0 0 0 1px rgba(82,255,168,0.02);
      }

      .prose pre code {
        background: transparent;
        border: 0;
        padding: 0;
        color: inherit;
      }

      .prose blockquote {
        margin: 1rem 0;
        padding: 0.8rem 0.95rem;
        border-left: 3px solid rgba(15,111,99,0.45);
        border-radius: 8px 12px 12px 8px;
        background: rgba(82,255,168,0.05);
        color: var(--muted);
      }

      @media (prefers-reduced-motion: no-preference) {
        .frame {
          animation: rise 520ms ease both;
        }

        .stagger > * {
          opacity: 0;
          transform: translateY(8px);
          animation: rise 420ms ease both;
        }

        .stagger > *:nth-child(2) { animation-delay: 70ms; }
        .stagger > *:nth-child(3) { animation-delay: 140ms; }
        .stagger > *:nth-child(4) { animation-delay: 210ms; }

        html.js .command-typing:not(.is-typing):not(.is-typed) code {
          display: inline-block;
          white-space: nowrap;
          overflow: hidden;
          width: 0;
          padding-right: 0;
        }

        html.js .command-typing.is-typing code {
          display: inline-block;
          white-space: nowrap;
          overflow: hidden;
          width: 0;
          animation:
            typeCommand var(--type-duration) steps(var(--type-ch)) var(--type-delay) both;
        }

        html.js .command-typing.is-typing code::after {
          content: "";
          position: absolute;
          top: 0.08em;
          right: -0.18ch;
          width: 2px;
          height: 1.05em;
          background: rgba(82,255,168,0.7);
          box-shadow: 0 0 10px rgba(82,255,168,0.2);
          animation: caretBlink 920ms step-end infinite;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
      }

      @keyframes rise {
        from {
          opacity: 0;
          transform: translateY(8px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @keyframes typeCommand {
        from {
          width: 0;
        }
        to {
          width: calc(var(--type-ch) * 1ch);
        }
      }

      @keyframes caretBlink {
        50% {
          opacity: 0;
        }
      }

      @media (max-width: 720px) {
        .frame {
          margin: 0.5rem auto;
          border-radius: 22px;
        }

        header.site {
          align-items: flex-start;
          flex-direction: column;
        }

        main {
          padding: 0.8rem;
        }

        .grid-2,
        .hero-grid {
          grid-template-columns: 1fr;
        }

        .section-head {
          align-items: flex-start;
          flex-direction: column;
        }

        .mini-stat-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div class="shell">
      <div class="frame">
        <header class="site">
          <a class="brand" href="/">
            <span class="traffic" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </span>
            <span class="brand-mark">/</span>
            <span class="brand-copy">
              <strong>gsisinna</strong>
              <span>~ /home/gsisinna/blog</span>
            </span>
          </a>
          <nav aria-label="Primary">
            <a href="/" aria-current={pathName === "/" ? "page" : undefined}>home</a>
            <a
              href="/journal/"
              aria-current={pathName.startsWith("/journal") ? "page" : undefined}
            >
              notes
            </a>
            <a href="/contact/" aria-current={pathName.startsWith("/contact") ? "page" : undefined}>
              contact
            </a>
          </nav>
        </header>
        <main id="main-content">
          <slot />
        </main>
        <footer class="site">
          © {currentYear} Gabriele Sisinna. All rights reserved.
          <br />
          <a href="/privacy/" style="text-decoration:none;">Privacy</a>
          {" · "}
          <a href="/terms/" style="text-decoration:none;">Terms</a>
        </footer>
      </div>
    </div>
    <script is:inline>
    (() => {
      const commands = Array.from(document.querySelectorAll(".command-typing"));
      if (commands.length === 0) return;

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (reduceMotion || !("IntersectionObserver" in window)) {
        for (const el of commands) el.classList.add("is-typed");
        return;
      }

      const onTypeEnd = (event) => {
        if (!(event.target instanceof HTMLElement)) return;
        if (event.animationName !== "typeCommand") return;
        const command = event.target.closest(".command-typing");
        if (!command) return;
        command.classList.remove("is-typing");
        command.classList.add("is-typed");
        event.target.removeEventListener("animationend", onTypeEnd);
      };

      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            const el = entry.target;
            if (!(el instanceof HTMLElement)) continue;
            if (el.classList.contains("is-typed") || el.classList.contains("is-typing")) {
              observer.unobserve(el);
              continue;
            }

            const code = el.querySelector("code");
            if (code instanceof HTMLElement) {
              const computed = getComputedStyle(el);
              const baseDelay = Number.parseFloat(computed.getPropertyValue("--type-delay")) || 0;
              const baseDuration =
                Number.parseFloat(computed.getPropertyValue("--type-duration")) || 1.1;
              const jitterDelay = Math.round((Math.random() * 180) - 60);
              const jitterDuration = (Math.random() * 0.28) - 0.1;
              el.style.setProperty("--type-delay", `${Math.max(0, baseDelay + jitterDelay)}ms`);
              el.style.setProperty(
                "--type-duration",
                `${Math.max(0.35, baseDuration + jitterDuration).toFixed(2)}s`
              );
              code.addEventListener("animationend", onTypeEnd);
            }

            el.classList.add("is-typing");
            observer.unobserve(el);
          }
        },
        {
          threshold: 0.6,
          rootMargin: "0px 0px -8% 0px"
        }
      );

      for (const el of commands) observer.observe(el);
    })();
    </script>
  </body>
</html>
